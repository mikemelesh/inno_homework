<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_app_model_form" model="ir.ui.view">
        <field name="name">app.model.form</field>
        <field name="model">app.model</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="text"/>
                        <field name="check_all"/>
                    </group>
                    <group>
                        <group string="Checks">
                            <field name="check1"/>
                            <field name="check2"/>
                        </group>
                        <group string="Selectors">
                            <field name="select1"/>
                            <field name="select2"/>
                        </group>
                    </group>
                    <group string="Booleans Grid">
                        <group>
                            <field name="boolean1"/>
                            <field name="boolean2"/>
                            <field name="boolean3"/>
                        </group>
                        <group>
                            <field name="boolean4"/>
                            <field name="boolean5"/>
                            <field name="boolean6"/>
                        </group>
                        <group>
                            <field name="boolean7"/>
                            <field name="boolean8"/>
                            <field name="boolean9"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_app_model_list" model="ir.ui.view">
        <field name="name">app.model.list</field>
        <field name="model">app.model</field>
        <field name="arch" type="xml">
            <list>
                <field name="text"/>
                <field name="select1"/>
                <field name="select2"/>
            </list>
        </field>
    </record>

    <record id="action_app_model" model="ir.actions.act_window">
        <field name="name">App Tasks</field>
        <field name="res_model">app.model</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_app_root" name="Inno App" sequence="10"/>
    <menuitem id="menu_app_tasks" name="Tasks" parent="menu_app_root" action="action_app_model" sequence="10"/>
</odoo>